# Vercel KV (Upstash Redis) - automatically set when you link a KV store in Vercel
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pusher (Real-time) — optional, falls back to polling if not set
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Admin (default PIN is 1234 if not set)
ADMIN_PIN=1234
